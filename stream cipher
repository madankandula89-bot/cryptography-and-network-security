ch=int(input("Enter Your Choice:"))
if ch==1:
    plain=input("Enter Bits for encryption:")
    key=input("Enter Key:")
    cipher=xorcs(plain,key)
    print("Ciphertext:", cipher)
elif ch==2:
    cipher=input("Enter Bits for decryption:")
    key=input("Enter Key:")
    decrypted = xorcs(cipher,key)
    print("Decrypted:", decrypted)
