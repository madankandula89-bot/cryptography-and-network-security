p=int(input("Enter a P:"))
g=int(input("Enter a G:"))
a=int(input("Enter a A:"))
b=int(input("Enter a B:"))
x=(g**a)%p
y=(g**b)%p
print("Public Key of A: ",x)
print("Public Key of B: ",y)
print("Key Exchange")
skeya=(y**a)%p
skeyb=(x**b)%p
print("Secret Key of A: ",skeya)
print("Secret Key of B: ",skeyb)
